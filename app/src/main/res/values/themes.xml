<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Glassmorphism Material 3 Theme -->
    <style name="Theme.Ringer" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/glass_primary</item>
        <item name="colorPrimaryVariant">@color/glass_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Surface / Glass colors -->
        <item name="colorSurface">@color/glass_surface</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/glass_surface_variant</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/glass_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Glass effect attributes -->
        <item name="glassBackground">@drawable/glass_background</item>
        <item name="glassCardStyle">@style/GlassCard</item>
    </style>

    <style name="Theme.Ringer.Transparent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <!-- Glass Card Style -->
    <style name="GlassCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="cardBackgroundColor">@color/glass_surface</item>
        <item name="android:foreground">@drawable/ripple_glass</item>
    </style>

</resources>