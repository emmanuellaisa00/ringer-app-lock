<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/glass_background"
    android:padding="20dp"
    tools:context=".SettingsActivity">

    <!-- Glass Header -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/header_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/glass_border"
        app:cardBackgroundColor="@color/glass_surface"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:text="@string/settings"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Timeout Section -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/timeout_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/glass_border"
        app:cardBackgroundColor="@color/glass_surface"
        app:layout_constraintTop_toBottomOf="@id/header_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/unlock_timeout_label"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/timeout_input"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/glass_button"
                    android:padding="14dp"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:inputType="number"
                    android:gravity="center"
                    android:hint="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="minutes"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Save Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/save_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="@string/save"
        android:textColor="@color/white"
        android:textSize="17sp"
        app:cornerRadius="18dp"
        app:backgroundTint="@color/glass_primary"
        app:layout_constraintTop_toBottomOf="@id/timeout_card" />

    <!-- Accessibility Status -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/access_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/glass_border"
        app:cardBackgroundColor="@color/glass_surface"
        app:layout_constraintTop_toBottomOf="@id/save_button">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/accessibility_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/accessibility_disabled"
                android:textColor="@color/white"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/enable_accessibility_btn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="@string/enable_accessibility"
                android:textAllCaps="false"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/glass_primary_variant"
                app:strokeColor="@color/glass_border"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Battery Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/disable_battery_btn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:text="@string/battery_optimization"
        android:textAllCaps="false"
        app:cornerRadius="14dp"
        app:backgroundTint="@color/glass_surface"
        app:strokeColor="@color/glass_border"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/access_card" />

</androidx.constraintlayout.widget.ConstraintLayout>