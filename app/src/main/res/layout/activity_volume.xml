<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <!-- App logo -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_launcher_speaker"
            android:alpha="0.8"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/volume_label"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Equalizer bars container -->
        <LinearLayout
            android:id="@+id/bars_container"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="40dp"
            android:orientation="horizontal"
            android:gravity="bottom|center"
            android:paddingHorizontal="16dp">

            <!-- 6 equalizer bars, each is a vertical LinearLayout -->
            <LinearLayout android:id="@+id/bar_1" style="@style/EqualizerBar" />
            <LinearLayout android:id="@+id/bar_2" style="@style/EqualizerBar" />
            <LinearLayout android:id="@+id/bar_3" style="@style/EqualizerBar" />
            <LinearLayout android:id="@+id/bar_4" style="@style/EqualizerBar" />
            <LinearLayout android:id="@+id/bar_5" style="@style/EqualizerBar" />
            <LinearLayout android:id="@+id/bar_6" style="@style/EqualizerBar" />

        </LinearLayout>

        <TextView
            android:id="@+id/volume_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/volume_max_hint"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:alpha="0.6" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
