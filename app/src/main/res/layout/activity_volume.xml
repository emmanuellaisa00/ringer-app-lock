<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp">

        <!-- App logo -->
        <ImageView
            android:id="@+id/speaker_icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_launcher_speaker"
            android:alpha="0.9"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/volume_label"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Volume percentage display -->
        <TextView
            android:id="@+id/volume_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="0%"
            android:textColor="@color/text_hint"
            android:textSize="48sp"
            android:fontFamily="sans-serif-light"
            android:alpha="0.9" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="MAX VOLUME"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:alpha="0.6" />

        <!-- Equalizer bars container -->
        <LinearLayout
            android:id="@+id/bars_container"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="28dp"
            android:orientation="horizontal"
            android:gravity="bottom|center"
            android:paddingHorizontal="8dp">

            <!-- 6 equalizer bars -->
            <LinearLayout android:id="@+id/bar_1" style="@style/EqualizerBar" />
            <LinearLayout android:id="@+id/bar_2" style="@style/EqualizerBar" />
            <LinearLayout android:id="@+id/bar_3" style="@style/EqualizerBar" />
            <LinearLayout android:id="@+id/bar_4" style="@style/EqualizerBar" />
            <LinearLayout android:id="@+id/bar_5" style="@style/EqualizerBar" />
            <LinearLayout android:id="@+id/bar_6" style="@style/EqualizerBar" />

        </LinearLayout>

        <!-- dB labels row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:layout_marginTop="8dp">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center"
                android:text="60Hz" android:textColor="@color/text_hint" android:textSize="9sp" android:alpha="0.5"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center"
                android:text="230Hz" android:textColor="@color/text_hint" android:textSize="9sp" android:alpha="0.5"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center"
                android:text="1kHz" android:textColor="@color/text_hint" android:textSize="9sp" android:alpha="0.5"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center"
                android:text="4kHz" android:textColor="@color/text_hint" android:textSize="9sp" android:alpha="0.5"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center"
                android:text="8kHz" android:textColor="@color/text_hint" android:textSize="9sp" android:alpha="0.5"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center"
                android:text="16kHz" android:textColor="@color/text_hint" android:textSize="9sp" android:alpha="0.5"/>
        </LinearLayout>

        <!-- Hint -->
        <TextView
            android:id="@+id/volume_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/volume_max_hint"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:alpha="0.5" />

    </LinearLayout>

    <!-- Overlay that fades in when all bars maxed -->
    <View
        android:id="@+id/transition_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/primary_variant"
        android:alpha="0"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
